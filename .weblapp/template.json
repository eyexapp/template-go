{
  "name": "go",
  "displayName": "Go Clean Architecture",
  "description": "Go backend with Clean Architecture, Chi v5 router, PostgreSQL, sqlx, and configuration management",
  "category": "backend",
  "language": "go",
  "framework": "chi",
  "stack": ["go", "chi-v5", "postgresql", "sqlx", "koanf", "zap", "validator-v10"],
  "features": ["clean-architecture", "rest-api", "database", "migrations", "logging", "configuration"],
  "commands": {
    "dev": "go run ./cmd/api",
    "build": "go build ./cmd/api",
    "test": "go test ./...",
    "lint": "golangci-lint run"
  },
  "packageManager": "go",
  "ci": {
    "workflowTemplate": "go",
    "runner": "ubuntu-latest",
    "runtime": {
      "name": "go",
      "version": "1.22",
      "setup": "actions/setup-go@v5",
      "cache": "go"
    },
    "services": {
      "postgres": {
        "image": "postgres:16",
        "env": {
          "POSTGRES_USER": "test",
          "POSTGRES_PASSWORD": "test",
          "POSTGRES_DB": "test_db"
        },
        "ports": ["5432:5432"],
        "options": "--health-cmd pg_isready --health-interval 10s --health-timeout 5s --health-retries 5"
      }
    },
    "steps": {
      "install": "go mod download",
      "build": "go build ./cmd/api",
      "test": "go test ./...",
      "lint": "golangci-lint run"
    }
  }
}
